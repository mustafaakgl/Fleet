# Copy to .env for production deploy: cp .env.production.example .env
# Required secrets — replace all CHANGE_ME values before go-live.

NODE_ENV=production

POSTGRES_DB=fleet
POSTGRES_USER=fleet
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://fleet:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/fleet

# openssl rand -base64 48
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM
JWT_EXPIRES_IN=8h

FRONTEND_URL=https://app.myfleet.app
NEXT_PUBLIC_API_URL=https://api.myfleet.app/api/v1
CORS_ORIGIN=https://app.myfleet.app

DATA_CONTROLLER_NAME=MyFleet GmbH
PRIVACY_CONTACT_EMAIL=privacy@myfleet.app
NEXT_PUBLIC_DATA_CONTROLLER_NAME=MyFleet GmbH
NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=privacy@myfleet.app

# --- SMTP (required in production) ---
SMTP_ENABLED=true
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASS=CHANGE_ME_SMTP_PASS
SMTP_FROM="MyFleet <noreply@myfleet.app>"
SMTP_VERIFY_TO=ops@myfleet.app

# --- Object storage (recommended: s3) ---
STORAGE_DRIVER=s3
S3_BUCKET=fleet-uploads-prod
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME

# --- Billing (Week 3) ---
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --- Observability ---
SENTRY_DSN=
SENTRY_RELEASE=

BACKEND_PORT=3000
