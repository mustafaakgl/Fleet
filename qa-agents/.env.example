# Copy this file to .env and fill in your real values.
# Never commit your real .env file.

OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=your_model_name_here
FLEET_REPO_PATH=..

# Dry-run mode: when "true", NO real OpenAI API call is made and deterministic
# mock responses are used instead. Useful for testing the LangGraph flow and
# report generation without consuming API quota. Set to "false" for real LLM runs.
QA_DRY_RUN=true
