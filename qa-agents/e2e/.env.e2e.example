# Fleet E2E (Playwright) environment configuration.
#
# Copy this file to `.env.e2e` and fill in real values. NEVER commit `.env.e2e`.
# Credentials are read at runtime; they are never hardcoded in the test code.
#
# BASE_URL must point at the Fleet frontend that serves the login UI.

BASE_URL=

# --- Role credentials (leave blank in the example file) ----------------------

ADMIN_EMAIL=
ADMIN_PASSWORD=

BOSS_EMAIL=
BOSS_PASSWORD=

ACCOUNTING_EMAIL=
ACCOUNTING_PASSWORD=

OFFICE_EMAIL=
OFFICE_PASSWORD=

DRIVER_EMAIL=
DRIVER_PASSWORD=

# --- Optional future-unblocking values --------------------------------------

PRIVATE_DOCUMENT_SELECTOR=
PRIVATE_DOCUMENT_TEXT=
TEST_TENANT_B_DOCUMENT_ID=
DOCUMENT_DETAIL_ROUTE_TEMPLATE=
