generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  boss
  accounting
  office
  driver
  customer
}

enum CompanyUserRole {
  viewer
  manager
}

enum UserStatus {
  active
  inactive
}

enum TenantStatus {
  provisioning
  active
  suspended
}

enum UserInvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum BillingPlan {
  basic
  pro
  enterprise
}

enum BillingStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  manual
}

enum BillingMode {
  stripe
  manual
}

enum DriverStatus {
  active
  on_leave
  sick
  inactive
  terminated
}

enum RiskLevel {
  green
  yellow
  red
}

enum VehicleStatus {
  active
  maintenance
  broken
  inactive
}

enum AssignmentStatus {
  planned
  confirmed
  in_progress
  completed
  cancelled
}

enum TransportRequestStatus {
  pending
  approved
  rejected
  needs_review
}

enum CalendarStatus {
  AT
  UT
  KT
  FT
  HO
  SCH
  GR
  AZ
  SZ
  US
  FR
  WE
  AB
  MT
}

enum CalendarSource {
  assignment
  leave
  manual
}

enum RequestType {
  vacation
  sick_leave
  training
  business_trip
  doctor_appointment
  special_leave
  overtime_compensation
  free_day
  uniform_delivery
  other
}

enum RequestStatus {
  pending
  approved
  rejected
  cancelled
  needs_review
}

enum DocumentOwnerType {
  driver
  vehicle
  company
  request
  transport_request
  accident
  cargo_damage
  vehicle_handover
  assignment
  service_record
  vehicle_equipment
}

enum DocumentStatus {
  valid
  expiring_soon
  expired
  missing
  archived
}

enum HandoverType {
  pickup
  return
}

enum HandoverPhotoStatus {
  not_required
  missing
  uploaded
  approved
  rejected
}

enum HandoverStatus {
  pending
  completed
}

enum WorkSessionEndReason {
  manual
  app_background
  logout
}

enum WorkSessionStatus {
  active
  ended
}

enum MessengerDepartment {
  dispatch
  hr
  accounting
  maintenance
  general
}

enum VehicleEquipmentStatus {
  active
  retired
}

enum IncidentType {
  vehicle_accident
  cargo_damage
}

enum IncidentStatus {
  reported
  under_review
  resolved
  rejected
}

enum CompanyEmailStatus {
  draft
  draft_ready
  needs_review
  sent
  failed
}

enum NotificationType {
  transport_request
  request
  document
  handover
  accident
  cargo_damage
  company_email
  reminder
  system
}

enum NotificationPriority {
  low
  medium
  high
  critical
}

enum NotificationStatus {
  unread
  read
}

enum ReminderStatus {
  open
  sent
  resolved
  ignored
}

enum ReminderType {
  license_expiry
  passport_expiry
  tuv_expiry
  sp_expiry
  insurance_expiry
  document_expiry
  custom
}

enum MessageTranslationStatus {
  not_requested
  pending
  translated
  failed
}

enum LocationSource {
  mobile
  telematics
}

enum LocationTrackingStatus {
  active
  paused
  denied
}

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  status       TenantStatus @default(provisioning)
  contactEmail String?
  contactPhone String?
  address      String?
  language     String       @default("de")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users                 User[]
  invitations           UserInvitation[]
  subscription          TenantSubscription?
  drivers               Driver[]
  vehicles              Vehicle[]
  companies             Company[]
  assignments           Assignment[]
  transportRequests     TransportRequest[]
  calendarEvents        CalendarEvent[]
  requests              Request[]
  documents             Document[]
  vehicleHandovers      VehicleHandover[]
  accidents             Accident[]
  companyEmails         CompanyEmail[]
  notifications         Notification[]
  reminders             Reminder[]
  morningCheckins       MorningCheckin[]
  serviceRecords        ServiceRecord[]
  conversations         Conversation[]
  auditLogs             AuditLog[]
  driverLocationHistory DriverLocationHistory[]
  driverLocationLatest  DriverLocationLatest[]
  customerAssignmentMessages CustomerAssignmentMessage[]
  workSessions          WorkSession[]
  vehicleEquipment      VehicleEquipment[]
}

model TenantSubscription {
  id                     String        @id @default(cuid())
  tenantId               String        @unique
  tenant                 Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                   BillingPlan   @default(basic)
  status                 BillingStatus @default(trialing)
  billingMode            BillingMode   @default(stripe)
  stripeCustomerId       String?       @unique
  stripeSubscriptionId   String?       @unique
  stripePriceId          String?
  vehicleLimit           Int           @default(15)
  seatLimit              Int           @default(5)
  monthlyAmountCents     Int           @default(29900)
  billingEmail           String?
  manualInvoiceReference String?
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([status])
  @@index([stripeCustomerId])
}

model User {
  id           String     @id @default(cuid())
  tenantId     String     @default("default-tenant")
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  fullName     String
  email        String
  passwordHash String
  role         UserRole
  status       UserStatus @default(active)
  language     String     @default("de")
  expoPushToken String?
  mfaEnabled       Boolean @default(false)
  mfaSecret        String?
  mfaPendingSecret String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  driver             Driver?
  createdAssignments Assignment[]   @relation("AssignmentCreatedBy")
  approvedRequests   Request[]      @relation("ApprovedRequests")
  uploadedDocuments  Document[]     @relation("DocumentUploadedBy")
  notifications      Notification[]
  createdConversations Conversation[]           @relation("ConversationCreatedBy")
  conversationParticipants ConversationParticipant[]
  sentMessages       Message[]                  @relation("MessageSentBy")
  messageReads       MessageRead[]
  auditLogs         AuditLog[]
  companyMemberships CompanyUser[]
  passwordResetTokens PasswordResetToken[]
  createdPasswordResets PasswordResetToken[] @relation("PasswordResetCreatedBy")
  sentInvitations   UserInvitation[] @relation("InvitationSentBy")
  customerAssignmentMessages CustomerAssignmentMessage[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model UserInvitation {
  id          String               @id @default(cuid())
  tenantId    String
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String
  fullName    String
  role        UserRole
  language    String               @default("de")
  tokenHash   String
  status      UserInvitationStatus @default(pending)
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  invitedBy   User                 @relation("InvitationSentBy", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())

  @@unique([tenantId, email])
  @@index([tokenHash])
  @@index([expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String?
  createdBy   User?     @relation("PasswordResetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Driver {
  id                 String       @id @default(cuid())
  tenantId           String       @default("default-tenant")
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userId             String?      @unique
  employeeNumber     String
  firstName          String
  lastName           String
  phone              String?
  email              String?
  licenseNumber      String?
  licenseExpiryDate  DateTime?
  passportNumber     String?
  passportExpiryDate DateTime?
  status             DriverStatus @default(active)
  riskLevel          RiskLevel    @default(green)
  notes              String?
  dateOfBirth        DateTime?    @db.Date
  vacationEntitlementDays Decimal @default(24) @db.Decimal(5, 2)
  vacationCarryOverDays   Decimal @default(0) @db.Decimal(5, 2)
  lastBirthdayNotifiedYear Int?
  locationTrackingConsentAt DateTime?
  locationTrackingStatus    LocationTrackingStatus @default(paused)
  locationTrackingEnabledAt DateTime?
  locationSharingStartedAt  DateTime?
  locationSharingEndedAt    DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  currentVehicles   Vehicle[]          @relation("CurrentVehicleDriver")
  assignments       Assignment[]
  transportRequests TransportRequest[]
  calendarEvents    CalendarEvent[]
  requests          Request[]
  vehicleHandovers  VehicleHandover[]
  accidents         Accident[]
  morningCheckins   MorningCheckin[]
  conversations     Conversation[]
  locationLatest    DriverLocationLatest?
  locationHistory   DriverLocationHistory[]
  workSessions      WorkSession[]
  serviceRecords    ServiceRecord[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
}

model Vehicle {
  id                     String        @id @default(cuid())
  tenantId               String        @default("default-tenant")
  tenant                 Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  plateNumber            String
  internalCode           String
  brand                  String
  model                  String
  year                   Int?
  vin                    String?
  status                 VehicleStatus @default(active)
  currentDriverId        String?
  tuvExpiryDate          DateTime?
  spExpiryDate           DateTime?
  insuranceExpiryDate    DateTime?
  registrationExpiryDate DateTime?
  photoUrl               String?
  notes                  String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  currentDriver Driver? @relation("CurrentVehicleDriver", fields: [currentDriverId], references: [id], onDelete: SetNull)

  assignments       Assignment[]
  transportRequests TransportRequest[]
  vehicleHandovers  VehicleHandover[]
  accidents         Accident[]
  serviceRecords    ServiceRecord[]
  locationLatestSnapshots DriverLocationLatest[]
  locationHistory   DriverLocationHistory[]
  equipment         VehicleEquipment[]

  @@unique([tenantId, plateNumber])
  @@unique([tenantId, internalCode])
  @@unique([tenantId, vin])
  @@index([tenantId])
}

model Company {
  id                  String   @id @default(cuid())
  tenantId            String   @default("default-tenant")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name                String
  email               String?
  phone               String?
  address             String?
  contactPerson       String?
  defaultDailyRevenue Decimal? @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  assignments       Assignment[]
  transportRequests TransportRequest[]
  accidents         Accident[]
  companyEmails     CompanyEmail[]
  companyUsers      CompanyUser[]
  portalSettings    CompanyPortalSettings?

  @@unique([tenantId, name])
  @@index([tenantId])
}

model CompanyUser {
  id        String          @id @default(cuid())
  userId    String
  companyId String
  role      CompanyUserRole @default(viewer)
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model CompanyPortalSettings {
  companyId          String   @id
  portalEnabled      Boolean  @default(true)
  showLiveTracking   Boolean  @default(true)
  showDriverFullName Boolean  @default(false)
  showInternalNotes  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Assignment {
  id              String           @id @default(cuid())
  tenantId        String           @default("default-tenant")
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId        String
  vehicleId       String
  companyId       String
  cargoName       String
  cargoOwner      String
  pickupAddress   String
  deliveryAddress String
  workDate        DateTime
  startTime       String
  endTime         String
  routeName            String?
  expectedDailyRevenue Decimal?         @db.Decimal(10, 2)
  status               AssignmentStatus @default(planned)
  notes                String?
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  driver           Driver            @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy        User              @relation("AssignmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  calendarEvents   CalendarEvent[]
  transportRequest TransportRequest? @relation("TransportRequestAssignment")
  vehicleHandovers VehicleHandover[]
  accidents        Accident[]
  morningCheckins  MorningCheckin[]
  customerMessages CustomerAssignmentMessage[]

  @@index([tenantId])
  @@index([driverId, workDate])
  @@index([vehicleId, workDate])
  @@index([companyId, workDate])
}

model CustomerAssignmentMessage {
  id           String   @id @default(cuid())
  tenantId     String   @default("default-tenant")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignmentId String
  senderUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  sender     User       @relation(fields: [senderUserId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([assignmentId, createdAt])
  @@index([senderUserId, createdAt])
}

model DriverLocationLatest {
  driverId   String         @id
  tenantId   String         @default("default-tenant")
  latitude   Decimal        @db.Decimal(10, 7)
  longitude  Decimal        @db.Decimal(10, 7)
  accuracyM  Float?
  speedMps   Float?
  headingDeg Float?
  altitudeM  Float?
  recordedAt DateTime
  receivedAt DateTime       @updatedAt
  source     LocationSource @default(mobile)
  vehicleId  String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driver  Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([receivedAt])
  @@index([vehicleId])
}

model DriverLocationHistory {
  id         String         @id @default(cuid())
  tenantId   String         @default("default-tenant")
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId   String
  vehicleId  String?
  latitude   Decimal        @db.Decimal(10, 7)
  longitude  Decimal        @db.Decimal(10, 7)
  accuracyM  Float?
  speedMps   Float?
  headingDeg Float?
  altitudeM  Float?
  recordedAt DateTime
  receivedAt DateTime       @default(now())
  source     LocationSource @default(mobile)

  driver  Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, recordedAt])
  @@index([vehicleId, recordedAt])
  @@index([recordedAt])
}

model TransportRequest {
  id              String                 @id @default(cuid())
  tenantId        String                 @default("default-tenant")
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId        String
  vehicleId       String
  companyId       String
  cargoName       String
  cargoOwner      String
  pickupAddress   String
  deliveryAddress String
  requestedDate   DateTime
  startTime       String
  endTime         String
  status          TransportRequestStatus @default(pending)
  conflictReason  String?
  assignmentId    String?                @unique
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  assignment Assignment? @relation("TransportRequestAssignment", fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, requestedDate])
  @@index([vehicleId, requestedDate])
  @@index([companyId, requestedDate])
}

model CalendarEvent {
  id           String         @id @default(cuid())
  tenantId     String         @default("default-tenant")
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId     String
  assignmentId String?
  requestId    String?
  date         DateTime
  status       CalendarStatus
  uiStatus     String?
  source       CalendarSource
  createdAt    DateTime       @default(now())

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  request    Request?    @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, date])
  @@index([requestId])
}

model Request {
  id           String        @id @default(uuid())
  tenantId     String        @default("default-tenant")
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId     String
  type         RequestType
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       RequestStatus @default(pending)
  approvedById String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  driver         Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  approvedBy     User?           @relation("ApprovedRequests", fields: [approvedById], references: [id], onDelete: SetNull)
  calendarEvents CalendarEvent[]

  @@index([tenantId])
  @@index([driverId, startDate, endDate])
}

model Document {
  id           String            @id @default(uuid())
  tenantId     String            @default("default-tenant")
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  ownerType    DocumentOwnerType
  ownerId      String
  documentType String
  fileName     String
  fileUrl      String?
  expiryDate   DateTime?
  status       DocumentStatus    @default(valid)
  notes        String?
  uploadedById String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  uploadedBy User? @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([ownerType, ownerId])
  @@index([status])
  @@index([documentType])
  @@index([expiryDate])
}

model VehicleHandover {
  id                String              @id @default(uuid())
  tenantId          String              @default("default-tenant")
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId          String
  vehicleId         String
  previousVehicleId String?
  assignmentId      String?
  handoverType      HandoverType
  handoverDateTime  DateTime
  photoRequired     Boolean             @default(false)
  photoStatus       HandoverPhotoStatus @default(not_required)
  damageDetected    Boolean             @default(false)
  damageNotes       String?
  equipmentFirstAidKit      Boolean?
  equipmentFireExtinguisher Boolean?
  equipmentStraps           Boolean?
  equipmentSafetyVest       Boolean?
  equipmentNotes            String?
  equipmentVerifiedAt       DateTime?
  status            HandoverStatus      @default(pending)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, handoverDateTime])
  @@index([vehicleId, handoverDateTime])
  @@index([assignmentId])
}

model WorkSession {
  id        String                @id @default(uuid())
  tenantId  String                @default("default-tenant")
  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId  String
  driver    Driver                @relation(fields: [driverId], references: [id], onDelete: Cascade)
  startedAt DateTime              @default(now())
  endedAt   DateTime?
  endReason WorkSessionEndReason?
  status    WorkSessionStatus     @default(active)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([tenantId])
  @@index([driverId, status])
  @@index([driverId, startedAt])
}

model VehicleEquipment {
  id           String                 @id @default(uuid())
  tenantId     String                 @default("default-tenant")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId    String
  vehicle      Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  name         String
  quantity     Int                    @default(1)
  serialNumber String?
  notes        String?
  status       VehicleEquipmentStatus @default(active)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([tenantId])
  @@index([vehicleId, status])
}

model Accident {
  id               String         @id @default(uuid())
  tenantId         String         @default("default-tenant")
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  type             IncidentType
  driverId         String
  vehicleId        String
  companyId        String?
  assignmentId     String?
  incidentDateTime DateTime
  location         String?
  description      String
  cargoName        String?
  cargoOwner       String?
  damageValue      Decimal?       @db.Decimal(12, 2)
  status           IncidentStatus @default(reported)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  company    Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, incidentDateTime])
  @@index([vehicleId, incidentDateTime])
  @@index([companyId, incidentDateTime])
  @@index([assignmentId])
  @@index([type, status])
}

model CompanyEmail {
  id             String             @id @default(uuid())
  tenantId       String             @default("default-tenant")
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  companyId      String
  date           DateTime
  subject        String
  recipientEmail String
  body           String
  status         CompanyEmailStatus @default(draft)
  lastSentAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@unique([companyId, date])
  @@index([companyId, date])
}

model Notification {
  id                String               @id @default(uuid())
  tenantId          String               @default("default-tenant")
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userId            String
  title             String
  message           String
  type              NotificationType
  priority          NotificationPriority @default(medium)
  status            NotificationStatus   @default(unread)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, status, createdAt])
  @@index([type, createdAt])
}

model Reminder {
  id               String         @id @default(uuid())
  tenantId         String         @default("default-tenant")
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  targetType       String
  targetId         String
  reminderType     ReminderType
  title            String
  description      String?
  dueDate          DateTime
  notifyBeforeDays Int
  status           ReminderStatus @default(open)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([tenantId, targetType, targetId, reminderType, dueDate, notifyBeforeDays])
  @@index([tenantId])
  @@index([status, dueDate])
  @@index([targetType, targetId])
}

enum MorningCheckinStatus {
  confirmed
  waiting_for_review
  missing_vehicle_plate
  missing_company
  conflict
  added_to_einsatzplan
  rejected
}

model MorningCheckin {
  id             String               @id @default(cuid())
  tenantId       String               @default("default-tenant")
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId       String
  date           DateTime
  submittedAt    DateTime             @default(now())
  vehiclePlate   String?
  companyName    String?
  cargoName      String?
  cargoQuantity  String?
  status         MorningCheckinStatus @default(waiting_for_review)
  conflictReason String?
  assignmentId   String?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, date])
  @@index([status, date])
}

model ServiceRecord {
  id            String   @id @default(cuid())
  tenantId      String   @default("default-tenant")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId     String
  driverId      String?
  date          DateTime
  serviceType   String
  vendor        String?
  repairCompany String
  costAmount    Decimal  @db.Decimal(10, 2)
  mileageKm     Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver  Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([vehicleId, date])
  @@index([driverId, date])
  @@index([repairCompany])
}

model Conversation {
  id            String              @id @default(cuid())
  tenantId      String              @default("default-tenant")
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId      String
  createdById   String
  department    MessengerDepartment @default(general)
  subject       String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  driver       Driver                     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  createdBy    User                       @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([tenantId])
  @@index([driverId, updatedAt])
  @@index([lastMessageAt])
  @@index([department])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           UserRole
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, conversationId])
}

model Message {
  id                String                   @id @default(cuid())
  conversationId    String
  senderUserId      String
  originalText      String
  translatedText    String?
  originalLanguage  String
  targetLanguage    String?
  translationStatus MessageTranslationStatus @default(not_requested)
  translatedAt      DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSentBy", fields: [senderUserId], references: [id], onDelete: Restrict)
  reads        MessageRead[]

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@index([messageId])
}

model AuditLog {
  id          String @id @default(cuid())
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUserId String?
  actorUser   User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String?

  summary   String?
  metadata  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([createdAt])
}
