generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  boss
  accounting
  office
  driver
  customer
}

enum CompanyUserRole {
  viewer
  manager
}

enum UserStatus {
  active
  inactive
}

enum TenantStatus {
  provisioning
  active
  suspended
}

enum UserInvitationStatus {
  pending
  accepted
  expired
  revoked
}

enum BillingPlan {
  basic
  pro
  enterprise
}

enum BillingStatus {
  trialing
  active
  past_due
  canceled
  unpaid
  manual
}

enum BillingMode {
  stripe
  manual
}

enum DriverStatus {
  active
  on_leave
  sick
  inactive
  terminated
}

enum RiskLevel {
  green
  yellow
  red
}

enum VehicleStatus {
  active
  maintenance
  broken
  inactive
}

enum AssignmentStatus {
  planned
  confirmed
  in_progress
  completed
  cancelled
}

enum TransportRequestStatus {
  pending
  approved
  rejected
  needs_review
}

enum CalendarStatus {
  AT
  UT
  KT
  FT
  HO
  SCH
  GR
  AZ
  SZ
  US
  FR
  WE
  AB
  MT
}

enum CalendarSource {
  assignment
  leave
  manual
}

enum RequestType {
  vacation
  sick_leave
  training
  business_trip
  doctor_appointment
  special_leave
  overtime_compensation
  free_day
  uniform_delivery
  other
}

enum RequestStatus {
  pending
  approved
  rejected
  cancelled
  needs_review
}

enum DocumentOwnerType {
  driver
  vehicle
  company
  request
  transport_request
  accident
  cargo_damage
  vehicle_handover
  assignment
  service_record
  vehicle_equipment
}

enum DocumentStatus {
  valid
  expiring_soon
  expired
  missing
  archived
}

enum HandoverType {
  pickup
  return
}

enum HandoverPhotoStatus {
  not_required
  missing
  uploaded
  approved
  rejected
}

enum HandoverPhotoValidationStatus {
  validated
  location_mismatch
}

enum HandoverStatus {
  pending
  completed
}

enum WorkSessionEndReason {
  manual
  app_background
  logout
}

enum WorkSessionStatus {
  active
  ended
}

enum MessengerDepartment {
  dispatch
  hr
  accounting
  maintenance
  general
}

enum VehicleEquipmentStatus {
  active
  retired
}

enum IncidentType {
  vehicle_accident
  cargo_damage
}

enum IncidentStatus {
  reported
  under_review
  resolved
  rejected
}

enum CompanyEmailStatus {
  draft
  draft_ready
  needs_review
  sent
  failed
}

enum NotificationType {
  transport_request
  request
  document
  handover
  accident
  cargo_damage
  company_email
  reminder
  system
}

enum NotificationPriority {
  low
  medium
  high
  critical
}

enum NotificationStatus {
  unread
  read
}

enum ReminderStatus {
  open
  sent
  resolved
  ignored
}

enum ReminderType {
  license_expiry
  passport_expiry
  tuv_expiry
  sp_expiry
  insurance_expiry
  document_expiry
  custom
}

enum LicenseCheckType {
  initial
  periodic
}

enum LicenseCheckStatus {
  pending
  approved
  rejected
}

enum LicenseComplianceBadge {
  green
  yellow
  red
}

enum VehicleCategory {
  truck
  transporter
  car
  special
}

enum DepartureCheckOverallStatus {
  ok
  maengel_gemeldet
}

enum DepartureCheckItemStatus {
  ok
  defekt
  na
}

enum DefectSource {
  departure_check
  manual_report
}

enum DefectSeverity {
  kritisch
  mittel
  gering
}

enum DefectStatus {
  offen
  in_reparatur
  behoben
  bestaetigt
}

enum FineViolationCategory {
  speed
  parking
  red_light
  distance
  other
}

enum FineMatchType {
  auto
  manual
  unmatched
}

enum FineStatus {
  neu
  fahrer_zugeordnet
  fahrer_benachrichtigt
  bezahlt
  widerspruch
  abgeschlossen
}

enum MessageTranslationStatus {
  not_requested
  pending
  translated
  failed
}

enum LocationSource {
  mobile
  telematics
}

/// Phone / device / API origin for fleet analytics (Faz 2-ready; distinct from live-tracking LocationSource).
enum FleetTelemetrySource {
  phone
  device
  api
}

enum FleetTripStatus {
  active
  closed
}

enum FleetDrivingEventType {
  speeding
  harsh_accel
  harsh_brake
}

enum LocationTrackingStatus {
  active
  paused
  denied
}

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  status       TenantStatus @default(provisioning)
  contactEmail String?
  contactPhone String?
  address      String?
  language     String       @default("de")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users                 User[]
  invitations           UserInvitation[]
  subscription          TenantSubscription?
  drivers               Driver[]
  vehicles              Vehicle[]
  companies             Company[]
  assignments           Assignment[]
  transportRequests     TransportRequest[]
  calendarEvents        CalendarEvent[]
  requests              Request[]
  documents             Document[]
  vehicleHandovers      VehicleHandover[]
  accidents             Accident[]
  companyEmails         CompanyEmail[]
  notifications         Notification[]
  reminders             Reminder[]
  morningCheckins       MorningCheckin[]
  serviceRecords        ServiceRecord[]
  conversations         Conversation[]
  auditLogs             AuditLog[]
  driverLocationHistory DriverLocationHistory[]
  driverLocationLatest  DriverLocationLatest[]
  customerAssignmentMessages CustomerAssignmentMessage[]
  workSessions          WorkSession[]
  vehicleEquipment      VehicleEquipment[]
  driverLicenses        DriverLicense[]
  licenseChecks         LicenseCheck[]
  checklistTemplates    ChecklistTemplate[]
  departureChecks       DepartureCheck[]
  defects               Defect[]
  defectStatusLogs      DefectStatusLog[]
  departureCheckReminders DepartureCheckReminderState[]
  fines                 Fine[]
  fineStatusLogs        FineStatusLog[]
  fleetTrips            FleetTrip[]
  fleetDrivingEvents    FleetDrivingEvent[]
  fleetFuelEntries      FleetFuelEntry[]
  fleetMaintenanceRules FleetMaintenanceRule[]
}

model TenantSubscription {
  id                     String        @id @default(cuid())
  tenantId               String        @unique
  tenant                 Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                   BillingPlan   @default(basic)
  status                 BillingStatus @default(trialing)
  billingMode            BillingMode   @default(stripe)
  stripeCustomerId       String?       @unique
  stripeSubscriptionId   String?       @unique
  stripePriceId          String?
  vehicleLimit           Int           @default(15)
  seatLimit              Int           @default(5)
  monthlyAmountCents     Int           @default(29900)
  billingEmail           String?
  manualInvoiceReference String?
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([status])
  @@index([stripeCustomerId])
}

model User {
  id           String     @id @default(cuid())
  tenantId     String     @default("default-tenant")
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  fullName     String
  email        String
  passwordHash String
  role         UserRole
  status       UserStatus @default(active)
  language     String     @default("de")
  expoPushToken String?
  mfaEnabled       Boolean @default(false)
  mfaSecret        String?
  mfaPendingSecret String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  driver             Driver?
  createdAssignments Assignment[]   @relation("AssignmentCreatedBy")
  approvedRequests   Request[]      @relation("ApprovedRequests")
  uploadedDocuments  Document[]     @relation("DocumentUploadedBy")
  notifications      Notification[]
  createdConversations Conversation[]           @relation("ConversationCreatedBy")
  conversationParticipants ConversationParticipant[]
  sentMessages       Message[]                  @relation("MessageSentBy")
  messageReads       MessageRead[]
  auditLogs         AuditLog[]
  companyMemberships CompanyUser[]
  passwordResetTokens PasswordResetToken[]
  createdPasswordResets PasswordResetToken[] @relation("PasswordResetCreatedBy")
  sentInvitations   UserInvitation[] @relation("InvitationSentBy")
  customerAssignmentMessages CustomerAssignmentMessage[]
  verifiedLicenseChecks      LicenseCheck[] @relation("LicenseCheckVerifiedBy")
  defectStatusChanges        DefectStatusLog[] @relation("DefectStatusChangedByUser")
  createdFines               Fine[] @relation("FineCreatedBy")
  fineStatusChanges          FineStatusLog[] @relation("FineStatusChangedByUser")
  refreshTokens              RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  /// Rotation chain: when a token is rotated, the replacement's id is stored here.
  replacedById String?
  revokedAt  DateTime?
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserInvitation {
  id          String               @id @default(cuid())
  tenantId    String
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email       String
  fullName    String
  role        UserRole
  language    String               @default("de")
  tokenHash   String
  status      UserInvitationStatus @default(pending)
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  invitedBy   User                 @relation("InvitationSentBy", fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime             @default(now())

  @@unique([tenantId, email])
  @@index([tokenHash])
  @@index([expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String?
  createdBy   User?     @relation("PasswordResetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Driver {
  id                 String       @id @default(cuid())
  tenantId           String       @default("default-tenant")
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userId             String?      @unique
  employeeNumber     String
  firstName          String
  lastName           String
  phone              String?
  email              String?
  licenseNumber      String?
  licenseExpiryDate  DateTime?
  passportNumber     String?
  passportExpiryDate DateTime?
  status             DriverStatus @default(active)
  riskLevel          RiskLevel    @default(green)
  notes              String?
  dateOfBirth        DateTime?    @db.Date
  homeAddressStreet  String?
  homeAddressZipCode String?
  homeAddressCity    String?
  homeAddressCountry String?
  vacationEntitlementDays Decimal @default(24) @db.Decimal(5, 2)
  vacationCarryOverDays   Decimal @default(0) @db.Decimal(5, 2)
  lastBirthdayNotifiedYear Int?
  locationTrackingConsentAt DateTime?
  locationTrackingStatus    LocationTrackingStatus @default(paused)
  locationTrackingEnabledAt DateTime?
  locationSharingStartedAt  DateTime?
  locationSharingEndedAt    DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  currentVehicles   Vehicle[]          @relation("CurrentVehicleDriver")
  assignments       Assignment[]
  transportRequests TransportRequest[]
  calendarEvents    CalendarEvent[]
  requests          Request[]
  vehicleHandovers  VehicleHandover[]
  accidents         Accident[]
  morningCheckins   MorningCheckin[]
  conversations     Conversation[]
  locationLatest    DriverLocationLatest?
  locationHistory   DriverLocationHistory[]
  workSessions      WorkSession[]
  serviceRecords    ServiceRecord[]
  driverLicenses    DriverLicense[]
  licenseChecks     LicenseCheck[]
  departureChecks   DepartureCheck[]
  reportedDefects   Defect[] @relation("DefectReportedBy")
  defectsToConfirm  Defect[] @relation("DefectConfirmationDriver")
  defectStatusChanges DefectStatusLog[] @relation("DefectStatusChangedByDriver")
  departureCheckReminders DepartureCheckReminderState[]
  fines                 Fine[]
  fineStatusChanges     FineStatusLog[] @relation("FineStatusChangedByDriver")
  fleetTrips            FleetTrip[]
  fleetDrivingEvents    FleetDrivingEvent[]
  fleetFuelEntries      FleetFuelEntry[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
}

model DriverLicense {
  id                 String    @id @default(cuid())
  tenantId           String    @default("default-tenant")
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId           String
  licenseNumber      String
  classes            String[]
  issuedAt           DateTime  @db.Date
  expiresAt          DateTime  @db.Date
  issuingAuthority   String
  frontPhotoStoredPath String?
  backPhotoStoredPath  String?
  nextCheckDueAt     DateTime? @db.Date
  checkRequestedAt   DateTime?
  lastReminderSentAt DateTime?
  lastEscalationSentAt DateTime?
  lastApprovedCheckAt DateTime?
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  driver Driver         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  checks LicenseCheck[]

  @@index([tenantId])
  @@index([driverId])
  @@index([expiresAt])
  @@index([nextCheckDueAt])
  @@index([deletedAt])
}

model LicenseCheck {
  id                    String             @id @default(cuid())
  tenantId              String             @default("default-tenant")
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId              String
  driverLicenseId       String?
  checkDate             DateTime           @default(now()) @db.Date
  checkType             LicenseCheckType
  status                LicenseCheckStatus @default(pending)
  verifiedById          String?
  verifiedAt            DateTime?
  rejectionReason       String?
  notes                 String?
  frontPhotoStoredPath  String?
  backPhotoStoredPath   String?
  selfiePhotoStoredPath String?
  photoMetadata         Json?
  dueAt                 DateTime?          @db.Date
  createdAt             DateTime           @default(now())

  driver        Driver         @relation(fields: [driverId], references: [id], onDelete: Cascade)
  driverLicense DriverLicense? @relation(fields: [driverLicenseId], references: [id], onDelete: SetNull)
  verifiedBy    User?          @relation("LicenseCheckVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, checkDate])
  @@index([status])
  @@index([driverLicenseId])
}

model Vehicle {
  id                     String        @id @default(cuid())
  tenantId               String        @default("default-tenant")
  tenant                 Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  plateNumber            String
  internalCode           String
  brand                  String
  model                  String
  year                   Int?
  vin                    String?
  status                 VehicleStatus @default(active)
  category               VehicleCategory @default(truck)
  currentDriverId        String?
  tuvExpiryDate          DateTime?
  spExpiryDate           DateTime?
  insuranceExpiryDate    DateTime?
  registrationExpiryDate DateTime?
  photoUrl               String?
  notes                  String?
  avgConsumptionLPer100Km Decimal?  @db.Decimal(6, 2)
  initialOdometerKm       Decimal?  @db.Decimal(12, 3)
  odometerCorrectedKm     Decimal?  @db.Decimal(12, 3)
  odometerCorrectedAt     DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  currentDriver Driver? @relation("CurrentVehicleDriver", fields: [currentDriverId], references: [id], onDelete: SetNull)

  assignments       Assignment[]
  transportRequests TransportRequest[]
  vehicleHandovers  VehicleHandover[]
  accidents         Accident[]
  serviceRecords    ServiceRecord[]
  locationLatestSnapshots DriverLocationLatest[]
  locationHistory   DriverLocationHistory[]
  equipment         VehicleEquipment[]
  departureChecks   DepartureCheck[]
  defects           Defect[]
  fines             Fine[]
  fleetTrips        FleetTrip[]
  fleetFuelEntries  FleetFuelEntry[]
  fleetMaintenanceRules FleetMaintenanceRule[]

  @@unique([tenantId, plateNumber])
  @@unique([tenantId, internalCode])
  @@unique([tenantId, vin])
  @@index([tenantId])
}

model Company {
  id                  String   @id @default(cuid())
  tenantId            String   @default("default-tenant")
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name                String
  email               String?
  phone               String?
  address             String?
  contactPerson       String?
  defaultDailyRevenue Decimal? @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  assignments       Assignment[]
  transportRequests TransportRequest[]
  accidents         Accident[]
  companyEmails     CompanyEmail[]
  companyUsers      CompanyUser[]
  portalSettings    CompanyPortalSettings?

  @@unique([tenantId, name])
  @@index([tenantId])
}

model CompanyUser {
  id        String          @id @default(cuid())
  userId    String
  companyId String
  role      CompanyUserRole @default(viewer)
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model CompanyPortalSettings {
  companyId          String   @id
  portalEnabled      Boolean  @default(true)
  showLiveTracking   Boolean  @default(true)
  showDriverFullName Boolean  @default(false)
  showInternalNotes  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Assignment {
  id              String           @id @default(cuid())
  tenantId        String           @default("default-tenant")
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId        String
  vehicleId       String
  companyId       String
  cargoName       String
  cargoOwner      String
  pickupAddress   String
  deliveryAddress String
  workDate        DateTime
  startTime       String
  endTime         String
  routeName            String?
  expectedDailyRevenue Decimal?         @db.Decimal(10, 2)
  status               AssignmentStatus @default(planned)
  notes                String?
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  driver           Driver            @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy        User              @relation("AssignmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  calendarEvents   CalendarEvent[]
  transportRequest TransportRequest? @relation("TransportRequestAssignment")
  vehicleHandovers VehicleHandover[]
  accidents        Accident[]
  morningCheckins  MorningCheckin[]
  customerMessages CustomerAssignmentMessage[]
  departureChecks  DepartureCheck[]
  matchedFines     Fine[]
  fleetTrips       FleetTrip[]

  @@index([tenantId])
  @@index([driverId, workDate])
  @@index([vehicleId, workDate])
  @@index([companyId, workDate])
}

model CustomerAssignmentMessage {
  id           String   @id @default(cuid())
  tenantId     String   @default("default-tenant")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignmentId String
  senderUserId String
  body         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  sender     User       @relation(fields: [senderUserId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([assignmentId, createdAt])
  @@index([senderUserId, createdAt])
}

model DriverLocationLatest {
  driverId   String         @id
  tenantId   String         @default("default-tenant")
  latitude   Decimal        @db.Decimal(10, 7)
  longitude  Decimal        @db.Decimal(10, 7)
  accuracyM  Float?
  speedMps   Float?
  headingDeg Float?
  altitudeM  Float?
  recordedAt DateTime
  receivedAt DateTime       @updatedAt
  source     LocationSource @default(mobile)
  vehicleId  String?

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driver  Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([receivedAt])
  @@index([vehicleId])
}

model DriverLocationHistory {
  id         String         @id @default(cuid())
  tenantId   String         @default("default-tenant")
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId   String
  vehicleId  String?
  latitude   Decimal        @db.Decimal(10, 7)
  longitude  Decimal        @db.Decimal(10, 7)
  accuracyM  Float?
  speedMps   Float?
  headingDeg Float?
  altitudeM  Float?
  recordedAt DateTime
  receivedAt DateTime       @default(now())
  source     LocationSource @default(mobile)

  driver  Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, recordedAt])
  @@index([vehicleId, recordedAt])
  @@index([recordedAt])
}

model TransportRequest {
  id              String                 @id @default(cuid())
  tenantId        String                 @default("default-tenant")
  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId        String
  vehicleId       String
  companyId       String
  cargoName       String
  cargoOwner      String
  pickupAddress   String
  deliveryAddress String
  requestedDate   DateTime
  startTime       String
  endTime         String
  status          TransportRequestStatus @default(pending)
  conflictReason  String?
  assignmentId    String?                @unique
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  company    Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  assignment Assignment? @relation("TransportRequestAssignment", fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, requestedDate])
  @@index([vehicleId, requestedDate])
  @@index([companyId, requestedDate])
}

model CalendarEvent {
  id           String         @id @default(cuid())
  tenantId     String         @default("default-tenant")
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId     String
  assignmentId String?
  requestId    String?
  date         DateTime
  status       CalendarStatus
  uiStatus     String?
  source       CalendarSource
  createdAt    DateTime       @default(now())

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  request    Request?    @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, date])
  @@index([requestId])
}

model Request {
  id           String        @id @default(uuid())
  tenantId     String        @default("default-tenant")
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId     String
  type         RequestType
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       RequestStatus @default(pending)
  approvedById String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  driver         Driver          @relation(fields: [driverId], references: [id], onDelete: Cascade)
  approvedBy     User?           @relation("ApprovedRequests", fields: [approvedById], references: [id], onDelete: SetNull)
  calendarEvents CalendarEvent[]

  @@index([tenantId])
  @@index([driverId, startDate, endDate])
}

model Document {
  id           String            @id @default(uuid())
  tenantId     String            @default("default-tenant")
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  ownerType    DocumentOwnerType
  ownerId      String
  documentType String
  fileName     String
  fileUrl      String?
  expiryDate   DateTime?
  status       DocumentStatus    @default(valid)
  notes        String?
  uploadedById String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  uploadedBy    User?          @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)
  handoverPhoto HandoverPhoto?

  @@index([tenantId])
  @@index([ownerType, ownerId])
  @@index([status])
  @@index([documentType])
  @@index([expiryDate])
}

model HandoverPhoto {
  id               String                        @id @default(uuid())
  handoverId       String
  slot             String
  documentId       String                        @unique
  fileHash         String                        @unique @map("file_hash")
  clientTakenAt    DateTime?                     @map("client_taken_at")
  exifTakenAt      DateTime?                     @map("exif_taken_at")
  gpsLat           Decimal?                      @db.Decimal(10, 7) @map("gps_lat")
  gpsLng           Decimal?                      @db.Decimal(10, 7) @map("gps_lng")
  deviceInfo       String?                       @map("device_info")
  validationStatus HandoverPhotoValidationStatus @default(validated) @map("validation_status")
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  handover VehicleHandover @relation(fields: [handoverId], references: [id], onDelete: Cascade)
  document Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([handoverId, slot])
  @@index([handoverId])
  @@map("handover_photos")
}

model VehicleHandover {
  id                String              @id @default(uuid())
  tenantId          String              @default("default-tenant")
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId          String
  vehicleId         String
  previousVehicleId String?
  assignmentId      String?
  handoverType      HandoverType
  handoverDateTime  DateTime
  photoRequired     Boolean             @default(false)
  photoStatus       HandoverPhotoStatus @default(not_required)
  damageDetected    Boolean             @default(false)
  damageNotes       String?
  equipmentFirstAidKit      Boolean?
  equipmentFireExtinguisher Boolean?
  equipmentStraps           Boolean?
  equipmentSafetyVest       Boolean?
  equipmentNotes            String?
  equipmentVerifiedAt       DateTime?
  status            HandoverStatus      @default(pending)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  driver         Driver          @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  assignment     Assignment?     @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  handoverPhotos HandoverPhoto[]

  @@index([tenantId])
  @@index([driverId, handoverDateTime])
  @@index([vehicleId, handoverDateTime])
  @@index([assignmentId])
}

model WorkSession {
  id        String                @id @default(uuid())
  tenantId  String                @default("default-tenant")
  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId  String
  driver    Driver                @relation(fields: [driverId], references: [id], onDelete: Cascade)
  startedAt DateTime              @default(now())
  endedAt   DateTime?
  endReason WorkSessionEndReason?
  status    WorkSessionStatus     @default(active)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  matchedFines Fine[]
  fleetTrips   FleetTrip[]

  @@index([tenantId])
  @@index([driverId, status])
  @@index([driverId, startedAt])
}

model VehicleEquipment {
  id           String                 @id @default(uuid())
  tenantId     String                 @default("default-tenant")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId    String
  vehicle      Vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  name         String
  quantity     Int                    @default(1)
  serialNumber String?
  notes        String?
  status       VehicleEquipmentStatus @default(active)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([tenantId])
  @@index([vehicleId, status])
}

model Accident {
  id               String         @id @default(uuid())
  tenantId         String         @default("default-tenant")
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  type             IncidentType
  driverId         String
  vehicleId        String
  companyId        String?
  assignmentId     String?
  incidentDateTime DateTime
  location         String?
  description      String
  cargoName        String?
  cargoOwner       String?
  cargoQuantity    String?
  damageValue      Decimal?       @db.Decimal(12, 2)
  status           IncidentStatus @default(reported)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle    Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  company    Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, incidentDateTime])
  @@index([vehicleId, incidentDateTime])
  @@index([companyId, incidentDateTime])
  @@index([assignmentId])
  @@index([type, status])
}

model CompanyEmail {
  id             String             @id @default(uuid())
  tenantId       String             @default("default-tenant")
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  companyId      String
  date           DateTime
  subject        String
  recipientEmail String
  body           String
  status         CompanyEmailStatus @default(draft)
  lastSentAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@unique([companyId, date])
  @@index([companyId, date])
}

model Notification {
  id                String               @id @default(uuid())
  tenantId          String               @default("default-tenant")
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userId            String
  title             String
  message           String
  type              NotificationType
  priority          NotificationPriority @default(medium)
  status            NotificationStatus   @default(unread)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, status, createdAt])
  @@index([type, createdAt])
}

model Reminder {
  id               String         @id @default(uuid())
  tenantId         String         @default("default-tenant")
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  targetType       String
  targetId         String
  reminderType     ReminderType
  title            String
  description      String?
  metadata         Json?
  dueDate          DateTime
  notifyBeforeDays Int
  status           ReminderStatus @default(open)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([tenantId, targetType, targetId, reminderType, title, dueDate, notifyBeforeDays])
  @@index([tenantId])
  @@index([status, dueDate])
  @@index([targetType, targetId])
}

enum MorningCheckinStatus {
  confirmed
  waiting_for_review
  missing_vehicle_plate
  missing_company
  conflict
  added_to_einsatzplan
  rejected
}

model MorningCheckin {
  id             String               @id @default(cuid())
  tenantId       String               @default("default-tenant")
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId       String
  date           DateTime
  submittedAt    DateTime             @default(now())
  vehiclePlate   String?
  companyName    String?
  cargoName      String?
  cargoQuantity  String?
  status         MorningCheckinStatus @default(waiting_for_review)
  conflictReason String?
  assignmentId   String?
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  driver     Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  assignment Assignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([driverId, date])
  @@index([status, date])
}

model ServiceRecord {
  id            String   @id @default(cuid())
  tenantId      String   @default("default-tenant")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId     String
  driverId      String?
  date          DateTime
  serviceType   String
  vendor        String?
  repairCompany String
  costAmount    Decimal  @db.Decimal(10, 2)
  mileageKm     Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver  Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)
  linkedDefects Defect[]

  @@index([tenantId])
  @@index([vehicleId, date])
  @@index([driverId, date])
  @@index([repairCompany])
}

model Conversation {
  id            String              @id @default(cuid())
  tenantId      String              @default("default-tenant")
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId      String
  createdById   String
  department    MessengerDepartment @default(general)
  subject       String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  driver       Driver                     @relation(fields: [driverId], references: [id], onDelete: Cascade)
  createdBy    User                       @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  participants ConversationParticipant[]
  messages     Message[]

  @@index([tenantId])
  @@index([driverId, updatedAt])
  @@index([lastMessageAt])
  @@index([department])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           UserRole
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, conversationId])
}

model Message {
  id                String                   @id @default(cuid())
  conversationId    String
  senderUserId      String
  originalText      String
  translatedText    String?
  originalLanguage  String
  targetLanguage    String?
  translationStatus MessageTranslationStatus @default(not_requested)
  translatedAt      DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSentBy", fields: [senderUserId], references: [id], onDelete: Restrict)
  reads        MessageRead[]

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, readAt])
  @@index([messageId])
}

model AuditLog {
  id          String @id @default(cuid())
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorUserId String?
  actorUser   User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String?

  summary   String?
  metadata  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@index([createdAt])
}

/// Admin-editable checklist template per vehicle category (Abfahrtskontrolle).
model ChecklistTemplate {
  id              String          @id @default(cuid())
  tenantId        String          @default("default-tenant")
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name            String
  vehicleCategory VehicleCategory
  description     String?
  isDefault       Boolean         @default(false)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           ChecklistTemplateItem[]
  departureChecks DepartureCheck[]

  @@index([tenantId])
  @@index([tenantId, vehicleCategory, isActive])
  @@index([tenantId, vehicleCategory, isDefault])
}

model ChecklistTemplateItem {
  id                   String            @id @default(cuid())
  templateId           String
  template             ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sortOrder            Int
  itemKey              String
  label                String
  description          String?
  requiresPhotoOnDefect Boolean          @default(true)
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  departureCheckItemResults DepartureCheckItemResult[]

  @@unique([templateId, itemKey])
  @@index([templateId, sortOrder])
}

/// Immutable pre-departure vehicle check (Abfahrtskontrolle).
model DepartureCheck {
  id                   String                      @id @default(cuid())
  tenantId             String                      @default("default-tenant")
  tenant               Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId             String
  vehicleId            String
  assignmentId         String?
  templateId           String
  workDate             DateTime                    @db.Date
  performedAt          DateTime
  latitude             Decimal?                    @db.Decimal(10, 7)
  longitude            Decimal?                    @db.Decimal(10, 7)
  accuracyM            Float?
  overallStatus        DepartureCheckOverallStatus
  templateNameSnapshot String
  signatureConfirmedAt DateTime?
  signatureMetadata    Json?
  clientSubmissionId   String?                     @unique
  offlineCapturedAt    DateTime?
  createdAt            DateTime                    @default(now())

  driver     Driver          @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle    Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  assignment Assignment?     @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  itemResults DepartureCheckItemResult[]
  defects    Defect[]

  @@unique([driverId, vehicleId, workDate])
  @@index([tenantId])
  @@index([driverId, workDate])
  @@index([vehicleId, workDate])
  @@index([assignmentId])
  @@index([performedAt])
}

model DepartureCheckItemResult {
  id                 String                   @id @default(cuid())
  departureCheckId   String
  templateItemId     String?
  itemKey            String
  itemLabel          String
  sortOrder          Int
  result             DepartureCheckItemStatus
  defectDescription  String?
  photoStoredPaths   String[]
  photoMetadata      Json?
  createdAt          DateTime                 @default(now())

  departureCheck DepartureCheck         @relation(fields: [departureCheckId], references: [id], onDelete: Cascade)
  templateItem   ChecklistTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)
  defects        Defect[]

  @@index([departureCheckId, sortOrder])
  @@index([templateItemId])
}

/// Vehicle defect (Mängel) with status chain and audit trail.
model Defect {
  id                         String         @id @default(cuid())
  tenantId                   String         @default("default-tenant")
  tenant                     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId                  String
  reportedByDriverId         String
  source                     DefectSource
  departureCheckId           String?
  departureCheckItemResultId String?
  title                      String?
  description                String
  severity                   DefectSeverity
  status                     DefectStatus   @default(offen)
  photoStoredPaths           String[]
  photoMetadata              Json?
  repairCompany              String?
  estimatedRepairDate        DateTime?      @db.Date
  serviceRecordId            String?
  confirmationDriverId       String?
  confirmedAt                DateTime?
  anonymizedAt               DateTime?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt

  vehicle                  Vehicle                   @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  reportedBy               Driver                    @relation("DefectReportedBy", fields: [reportedByDriverId], references: [id], onDelete: Restrict)
  departureCheck           DepartureCheck?           @relation(fields: [departureCheckId], references: [id], onDelete: SetNull)
  departureCheckItemResult DepartureCheckItemResult? @relation(fields: [departureCheckItemResultId], references: [id], onDelete: SetNull)
  serviceRecord            ServiceRecord?            @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)
  confirmationDriver       Driver?                   @relation("DefectConfirmationDriver", fields: [confirmationDriverId], references: [id], onDelete: SetNull)
  statusLogs               DefectStatusLog[]

  @@index([tenantId])
  @@index([vehicleId, status])
  @@index([vehicleId, severity, status])
  @@index([reportedByDriverId, createdAt])
  @@index([confirmationDriverId, status])
  @@index([departureCheckId])
  @@index([anonymizedAt])
}

/// Immutable audit log for every defect status transition.
model DefectStatusLog {
  id                  String        @id @default(cuid())
  tenantId            String        @default("default-tenant")
  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  defectId            String
  fromStatus          DefectStatus?
  toStatus            DefectStatus
  changedByUserId     String?
  changedByDriverId   String?
  note                String?
  repairCompany       String?
  estimatedRepairDate DateTime?     @db.Date
  createdAt           DateTime      @default(now())

  defect          Defect  @relation(fields: [defectId], references: [id], onDelete: Cascade)
  changedByUser   User?   @relation("DefectStatusChangedByUser", fields: [changedByUserId], references: [id], onDelete: SetNull)
  changedByDriver Driver? @relation("DefectStatusChangedByDriver", fields: [changedByDriverId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([defectId, createdAt])
}

/// Daily reminder / escalation state when morning departure check is missing.
model DepartureCheckReminderState {
  id                   String    @id @default(cuid())
  tenantId             String    @default("default-tenant")
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  driverId             String
  workDate             DateTime  @db.Date
  lastReminderSentAt   DateTime?
  lastEscalationSentAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, workDate])
  @@index([tenantId])
  @@index([workDate])
}

/// Traffic fine (Bußgeld) with driver matching and status workflow.
model Fine {
  id                      String                @id @default(cuid())
  tenantId                String                @default("default-tenant")
  tenant                  Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId               String
  driverId                String?
  matchType               FineMatchType         @default(unmatched)
  matchedWorkSessionId    String?
  matchedAssignmentId     String?
  violationAt             DateTime
  violationLocation       String
  violationType           String
  violationCategory       FineViolationCategory
  amount                  Decimal?              @db.Decimal(10, 2)
  paymentDueDate          DateTime?             @db.Date
  noticeDate              DateTime?             @db.Date
  documentStoredPath      String?
  documentMimeType        String?
  status                  FineStatus            @default(neu)
  notes                   String?
  matchCandidates         Json?
  matchToleranceMinutes   Int                   @default(30)
  driverNotifiedAt        DateTime?
  driverAcknowledgedAt    DateTime?
  driverAckMetadata       Json?
  lastDriverReminderSentAt DateTime?
  lastDriverEscalationSentAt DateTime?
  lastPaymentReminderDays Int?
  lastPaymentReminderSentAt DateTime?
  createdByUserId         String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  vehicle              Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver               Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  matchedWorkSession   WorkSession? @relation(fields: [matchedWorkSessionId], references: [id], onDelete: SetNull)
  matchedAssignment    Assignment?  @relation(fields: [matchedAssignmentId], references: [id], onDelete: SetNull)
  createdBy            User?        @relation("FineCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  statusLogs             FineStatusLog[]

  @@index([tenantId])
  @@index([vehicleId, violationAt])
  @@index([driverId, violationAt])
  @@index([status])
  @@index([paymentDueDate])
  @@index([noticeDate])
  @@index([matchType])
  @@index([violationCategory])
}

/// Immutable audit log for every fine status transition.
model FineStatusLog {
  id                String      @id @default(cuid())
  tenantId          String      @default("default-tenant")
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  fineId            String
  fromStatus        FineStatus?
  toStatus          FineStatus
  changedByUserId   String?
  changedByDriverId String?
  note              String?
  createdAt         DateTime    @default(now())

  fine            Fine    @relation(fields: [fineId], references: [id], onDelete: Cascade)
  changedByUser   User?   @relation("FineStatusChangedByUser", fields: [changedByUserId], references: [id], onDelete: SetNull)
  changedByDriver Driver? @relation("FineStatusChangedByDriver", fields: [changedByDriverId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([fineId, createdAt])
}

// --- Fleet analytics (phone GPS Phase 1; Faz 2 device/API adapters write same tables) ---

model FleetTrip {
  id             String               @id @default(cuid())
  tenantId       String               @default("default-tenant")
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId      String
  driverId       String
  source         FleetTelemetrySource @default(phone)
  startedAt      DateTime
  endedAt        DateTime?
  distanceKm     Decimal?             @db.Decimal(12, 3)
  durationS      Int?
  avgSpeedKmh    Decimal?             @db.Decimal(8, 2)
  maxSpeedKmh    Decimal?             @db.Decimal(8, 2)
  idleS          Int?
  score          Decimal?             @db.Decimal(5, 2)
  hasDataGap     Boolean              @default(false)
  status         FleetTripStatus      @default(active)
  assignmentId   String?
  workSessionId  String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  vehicle      Vehicle                  @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver       Driver                   @relation(fields: [driverId], references: [id], onDelete: Restrict)
  assignment   Assignment?              @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  workSession  WorkSession?             @relation(fields: [workSessionId], references: [id], onDelete: SetNull)
  locationPoints FleetTripLocationPoint[]
  drivingEvents  FleetDrivingEvent[]

  @@index([tenantId])
  @@index([vehicleId, startedAt])
  @@index([driverId, startedAt])
  @@index([status, startedAt])
  @@index([assignmentId])
  @@index([workSessionId])
  @@map("fleet_trips")
}

model FleetTripLocationPoint {
  id          String               @id @default(cuid())
  tripId      String
  recordedAt  DateTime
  latitude    Decimal              @db.Decimal(10, 7)
  longitude   Decimal              @db.Decimal(10, 7)
  speedKmh    Float?
  headingDeg  Float?
  accuracyM   Float?
  source      FleetTelemetrySource @default(phone)
  receivedAt  DateTime             @default(now())

  trip FleetTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, recordedAt, latitude, longitude])
  @@index([tripId, recordedAt])
  @@map("fleet_trip_location_points")
}

model FleetDrivingEvent {
  id         String                @id @default(cuid())
  tenantId   String                @default("default-tenant")
  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  tripId     String
  driverId   String
  type       FleetDrivingEventType
  occurredAt DateTime
  latitude   Decimal               @db.Decimal(10, 7)
  longitude  Decimal               @db.Decimal(10, 7)
  value      Decimal               @db.Decimal(10, 3)
  threshold  Decimal               @db.Decimal(10, 3)
  createdAt  DateTime              @default(now())

  trip   FleetTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver Driver    @relation(fields: [driverId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tripId, occurredAt])
  @@index([driverId, occurredAt])
  @@index([type, occurredAt])
  @@map("fleet_driving_events")
}

model FleetFuelEntry {
  id                 String   @id @default(cuid())
  tenantId           String   @default("default-tenant")
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId          String
  driverId           String
  enteredAt          DateTime
  liters             Decimal  @db.Decimal(10, 3)
  totalCost          Decimal  @db.Decimal(12, 2)
  currency           String   @default("EUR")
  odometerKm         Decimal? @db.Decimal(12, 3)
  isFullTank         Boolean  @default(false)
  receiptStoredPath  String?
  receiptMimeType    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([vehicleId, enteredAt])
  @@index([driverId, enteredAt])
  @@map("fleet_fuel_entries")
}

model FleetMaintenanceRule {
  id              String    @id @default(cuid())
  tenantId        String    @default("default-tenant")
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  vehicleId       String
  name            String
  intervalKm      Decimal?  @db.Decimal(12, 3)
  intervalDays    Int?
  lastDoneAtKm    Decimal?  @db.Decimal(12, 3)
  lastDoneAtDate  DateTime? @db.Date
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([vehicleId])
  @@map("fleet_maintenance_rules")
}
