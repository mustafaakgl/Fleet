DATABASE_URL="postgresql://fleet:fleet123@localhost:5432/fleet"
# For Docker Compose backend container, use:
# DATABASE_URL="postgresql://fleet:fleet123@postgres:5432/fleet"
# Generate: openssl rand -base64 32
JWT_SECRET="development_jwt_secret"
JWT_EXPIRES_IN="8h"
FRONTEND_URL="http://localhost:3001"
DATA_CONTROLLER_NAME="[FIRMENNAME]"
PRIVACY_CONTACT_EMAIL="privacy@example.com"
LOCATION_HISTORY_RETENTION_DAYS=90
RETENTION_CRON_ENABLED=true
# Production: SMTP_ENABLED=true is enforced when NODE_ENV=production (see docs/ops/SMTP-GO-LIVE.md)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MyFleet <noreply@myfleet.app>"
# Optional: recipient for `npm run verify:smtp` pre-deploy test
SMTP_VERIFY_TO=
# Production: set STRIPE_ENABLED=true + live keys (see docs/ops/STRIPE-GO-LIVE.md)
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Requires Stripe Tax registration on your account
STRIPE_AUTOMATIC_TAX=false
PORT=3000
# Ops: probe GET /api/v1/health (liveness) and GET /api/v1/health/ready (DB)
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate
DEEPL_TIMEOUT_MS=5000
MESSENGER_TRANSLATION_ENABLED=true

# Object storage (local disk by default; set STORAGE_DRIVER=s3 for production)
STORAGE_DRIVER=local
S3_BUCKET=fleet-uploads
S3_REGION=eu-central-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Error monitoring (optional)
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# GDPR retention (daily cron at 03:00 Europe/Berlin)
AUDIT_LOG_RETENTION_DAYS=730
NOTIFICATION_RETENTION_DAYS=730
MESSAGE_RETENTION_DAYS=730
DOCUMENT_EXPIRY_GRACE_DAYS=30

# Daily backup: scripts/backup-daily.sh (cron + DATABASE_URL)
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
