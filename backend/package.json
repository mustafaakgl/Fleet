{
  "name": "fleet-backend",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "scripts": {
    "start": "node --env-file=.env dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "postinstall": "prisma generate",
    "prestart:dev": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "verify:smtp": "ts-node scripts/verify-smtp.ts",
    "verify:stripe": "ts-node scripts/verify-stripe.ts",
    "verify:s3": "ts-node scripts/verify-s3.ts",
    "test": "node -r ts-node/register/transpile-only --test src/tenant/tenant-scoped-models.spec.ts src/tenant/tenant-access.service.spec.ts src/tenant/tenant-prisma.extension.spec.ts src/vehicle-handovers/handover-photo-validation.util.spec.ts src/vehicle-handovers/handover-photo.util.spec.ts src/fleet/core/fleet-trip-locations.util.spec.ts src/fleet/core/fleet-trip-processing.util.spec.ts src/fleet/core/fleet-driving-events.util.spec.ts src/fleet/core/fleet-fuel-consumption.util.spec.ts src/fleet/core/fleet-fuel-estimation.util.spec.ts src/fleet/core/fleet-odometer.util.spec.ts src/fleet/core/fleet-maintenance.util.spec.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@nestjs/common": "^11.1.23",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.23",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.16.2",
    "@sentry/node": "^10.56.0",
    "archiver": "^8.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "exifr": "^7.1.3",
    "fast-check": "^4.8.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "multer": "^2.2.0",
    "nodemailer": "^8.0.10",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.2.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
