{
  "name": "fleet",
  "private": true,
  "engines": {
    "node": ">=20.9 <23"
  },
  "scripts": {
    "dev": "node scripts/dev-workspace.mjs",
    "dev:lts": "node scripts/dev-workspace.mjs",
    "dev:full": "node scripts/dev-workspace.mjs",
    "dev:frontend": "node scripts/dev-next.mjs dev",
    "dev:backend": "node scripts/dev-backend.mjs",
    "build": "npm --prefix frontend run build",
    "start": "node scripts/dev-next.mjs start",
    "lint": "npm --prefix frontend run lint",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:seed": "docker compose exec backend npx prisma db seed"
  },
  "dependencies": {
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0"
  }
}
